# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Models
GROQ_MODEL=gemma-7b-it
GEMINI_MODEL=gemini-2.0-flash-exp

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# Email Configuration
SMTP_FROM_EMAIL=from_email@example.com
SMTP_FROM_NAME=Company Name
GMAIL_APP_PASSWORD=app_password

# Security
JWT_SECRET_KEY=secret_key

# ML Models
HUGGINGFACE_HUB_TOKEN=huggingface_token

# Azure Storage (Memory Vault) - Commented out
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account_name;AccountKey=your_account_key;EndpointSuffix=core.windows.net

# Google Cloud Storage
GCS_BUCKET_NAME=your_gcs_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service_account_key.json